<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/rootScroll"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/app_background"
    android:clipToPadding="false"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/page_padding">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/pocket_surface"
            app:cardCornerRadius="8dp"
            app:cardElevation="2dp"
            app:strokeColor="@color/pocket_glass_line"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="@dimen/card_padding">

                <ImageView
                    android:id="@+id/logoView"
                    android:layout_width="58dp"
                    android:layout_height="58dp"
                    android:background="@drawable/card_bg"
                    android:contentDescription="@string/app_name"
                    android:padding="4dp"
                    android:scaleType="centerCrop"
                    android:src="@drawable/logo" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/app_name"
                        android:textColor="@color/pocket_text"
                        android:textSize="25sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/subtitleText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:ellipsize="end"
                        android:maxLines="2"
                        android:text="Share a device folder over your local network"
                        android:textColor="@color/pocket_muted"
                        android:textSize="14sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="end"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/statusBadge"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/status_stopped"
                        android:paddingStart="12dp"
                        android:paddingTop="6dp"
                        android:paddingEnd="12dp"
                        android:paddingBottom="6dp"
                        android:text="Stopped"
                        android:textColor="@color/pocket_text"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/themeToggleButton"
                        style="@style/Widget.PocketLAN.Button"
                        android:layout_width="54dp"
                        android:layout_height="44dp"
                        android:layout_marginTop="8dp"
                        android:backgroundTint="@color/pocket_cyan"
                        android:contentDescription="Toggle light or dark mode"
                        android:insetLeft="0dp"
                        android:insetRight="0dp"
                        android:minWidth="0dp"
                        android:paddingStart="0dp"
                        android:paddingEnd="0dp"
                        app:icon="@drawable/ic_moon"
                        app:iconGravity="textStart"
                        app:iconPadding="0dp"
                        app:iconTint="@color/pocket_action_text" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:cardBackgroundColor="@color/pocket_surface"
            app:cardCornerRadius="8dp"
            app:cardElevation="2dp"
            app:strokeColor="@color/pocket_glass_line"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/card_padding">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Folder"
                    android:textColor="@color/pocket_text"
                    android:textSize="17sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/folderText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/card_bg"
                    android:minHeight="54dp"
                    android:padding="14dp"
                    android:text="No folder selected"
                    android:textColor="@color/pocket_muted"
                    android:textSize="14sp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/chooseFolderButton"
                    style="@style/Widget.PocketLAN.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:text="Choose folder"
                    android:textColor="@color/pocket_cyan"
                    app:icon="@android:drawable/ic_menu_upload"
                    app:iconGravity="textStart"
                    app:strokeColor="@color/pocket_cyan" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:cardBackgroundColor="@color/pocket_surface"
            app:cardCornerRadius="8dp"
            app:cardElevation="2dp"
            app:strokeColor="@color/pocket_glass_line"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/card_padding">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Network"
                    android:textColor="@color/pocket_text"
                    android:textSize="17sp"
                    android:textStyle="bold" />

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/customIpLayout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:hint="Custom IP (optional)"
                    app:boxBackgroundColor="@color/pocket_surface_alt"
                    app:boxStrokeColor="@color/pocket_cyan"
                    app:helperText="Leave blank to use the detected LAN IP"
                    app:helperTextTextColor="@color/pocket_muted"
                    app:hintTextColor="@color/pocket_muted">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/customIpInput"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="phone"
                        android:maxLength="15"
                        android:textColor="@color/pocket_text"
                        android:textColorHint="@color/pocket_muted" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/portLayout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:hint="Port"
                    app:boxBackgroundColor="@color/pocket_surface_alt"
                    app:boxStrokeColor="@color/pocket_cyan"
                    app:hintTextColor="@color/pocket_muted">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/portInput"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="number"
                        android:maxLength="5"
                        android:text="3000"
                        android:textColor="@color/pocket_text"
                        android:textColorHint="@color/pocket_muted" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/pinLayout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:hint="Browser PIN (optional)"
                    app:boxBackgroundColor="@color/pocket_surface_alt"
                    app:boxStrokeColor="@color/pocket_cyan"
                    app:endIconMode="password_toggle"
                    app:hintTextColor="@color/pocket_muted">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/pinInput"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textPassword"
                        android:maxLength="64"
                        android:textColor="@color/pocket_text"
                        android:textColorHint="@color/pocket_muted" />
                </com.google.android.material.textfield.TextInputLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:orientation="horizontal">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/serverToggleButton"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="8dp"
                        android:layout_weight="1"
                        android:backgroundTint="@color/pocket_emerald"
                        android:text="Start server"
                        android:textColor="@color/pocket_action_text"
                        app:icon="@android:drawable/ic_media_play"
                        app:iconGravity="textStart"
                        app:iconTint="@color/pocket_action_text" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/restartButton"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:layout_weight="1"
                        android:backgroundTint="@color/pocket_amber"
                        android:text="Restart"
                        android:textColor="@color/pocket_action_text"
                        app:icon="@android:drawable/ic_popup_sync"
                        app:iconGravity="textStart"
                        app:iconTint="@color/pocket_action_text" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:cardBackgroundColor="@color/pocket_surface"
            app:cardCornerRadius="8dp"
            app:cardElevation="2dp"
            app:strokeColor="@color/pocket_glass_line"
            app:strokeWidth="1dp">

            <LinearLayout
                android:id="@+id/linksSection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/card_padding">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Browser links"
                    android:textColor="@color/pocket_text"
                    android:textSize="17sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:id="@+id/linksContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:orientation="vertical" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="28dp"
            app:cardBackgroundColor="@color/pocket_surface"
            app:cardCornerRadius="8dp"
            app:cardElevation="2dp"
            app:strokeColor="@color/pocket_glass_line"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/card_padding">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Activity"
                    android:textColor="@color/pocket_text"
                    android:textSize="17sp"
                    android:textStyle="bold" />

                <ScrollView
                    android:id="@+id/logsScrollView"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/log_panel_height"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/card_bg"
                    android:fillViewport="true"
                    android:nestedScrollingEnabled="true"
                    android:padding="14dp">

                    <TextView
                        android:id="@+id/logsText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="monospace"
                        android:text="No activity yet. Start the server to see events here."
                        android:textColor="@color/pocket_muted"
                        android:textIsSelectable="true"
                        android:textSize="12sp" />
                </ScrollView>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>
</ScrollView>
